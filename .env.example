# Copy this file to .env and fill in real values for services you use.

APP_NAME="AI Tenant Screener"
# Generate a strong unique value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED in production (startup refuses to run with the dev default).
SECRET_KEY="change-me"
ADMIN_EMAIL="admin@example.com"
# Change this before deploying — the first super_admin is seeded from it.
ADMIN_PASSWORD="Admin123!"
APP_URL="http://localhost:8000"
# Use "production" for live deployments. Production REQUIRES https APP_URL,
# a strong SECRET_KEY, a non-default ADMIN_PASSWORD, ENCRYPTION_KEY, and
# TELNYX_PUBLIC_KEY — the app fails fast at startup otherwise.
ENVIRONMENT="development"
DEBUG="true"
# Directory for rotating JSON log files (used when ENVIRONMENT=production).
LOG_DIR="./logs"

# Supabase Postgres. Paste a connection string from Supabase Dashboard > Connect.
# URL-encode special characters in your password. This is required for @.
# Example password "pa@ss:word" becomes "pa%40ss%3Aword".
#
# Direct connection, best for persistent servers with IPv6 or Supabase IPv4 add-on:
# DATABASE_URL="postgresql://postgres:pa%40ss%3Aword@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
#
# Shared pooler session mode, best for persistent servers on IPv4-only networks:
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:pa%40ss%3Aword@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
#
# Transaction pooler, only for serverless/short-lived workers:
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:pa%40ss%3Aword@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_SSL="auto"
DATABASE_POOL_MODE="auto"
# auto | upgrade | check | create_all | skip.
# Production defaults to "check": run `alembic upgrade head` before deploying.
DATABASE_MIGRATION_MODE="auto"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="10"
DATABASE_POOL_RECYCLE_SECONDS="1800"
DATABASE_CONNECT_TIMEOUT_SECONDS="10"

SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_JWKS_URL="https://[PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json"
SUPABASE_STORAGE_BUCKET="call-recordings"

# Redis uses three logical databases to keep cache, the task queue, and task
# results from colliding. With docker-compose the host is "redis" not "localhost".
# IMPORTANT: set the Redis eviction policy to "noeviction" (or "volatile-lru").
# DB /1 is a Celery broker — "allkeys-lru" could silently drop queued emails.
# Usage is tiny and fully TTL-bounded, so 256 MB is far more than enough.
REDIS_URL="redis://localhost:6379/0"           # cache, rate limits, idempotency
CELERY_BROKER_URL="redis://localhost:6379/1"   # Celery task queue
CELERY_RESULT_BACKEND="redis://localhost:6379/2"  # Celery results (ignored)

TELNYX_API_KEY=""
# REQUIRED in production to verify inbound webhook signatures.
TELNYX_PUBLIC_KEY=""
TELNYX_PHONE_NUMBER=""

DEEPGRAM_API_KEY=""
GROQ_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""

GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_TTS_PROJECT_ID=""

RESEND_API_KEY=""
EMAIL_FROM="screening@example.com"
EMAIL_FROM_NAME="AI Screening Platform"

# REQUIRED in production. Must be a valid Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Set this BEFORE saving any provider API keys in the admin panel.
ENCRYPTION_KEY=""
DEFAULT_PROPERTY_NAME="Ready Rentals Online"
DEFAULT_LANDLORD_EMAIL=""
DEFAULT_AGENT_NAME="Ready Rentals assistant"

ACTIVE_LLM_PROVIDER="groq"
ACTIVE_STT_PROVIDER="deepgram"
ACTIVE_TTS_PROVIDER="deepgram"
ACTIVE_GROQ_MODEL="llama-3.3-70b-versatile"
ACTIVE_OPENAI_MODEL="gpt-4o-mini"
ACTIVE_OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
ACTIVE_GEMINI_MODEL="gemini-2.5-flash"
DEEPGRAM_MODEL="nova-3"
TTS_VOICE_GOOGLE="en-US-Wavenet-D"
TTS_VOICE_DEEPGRAM="aura-2-thalia-en"
TTS_SPEED="1.0"
